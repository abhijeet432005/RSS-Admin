# Base URL of your REST API, e.g. https://api.yourngo.org/v1
# Leave this unset/blank to run entirely on the built-in mock data
# (useful for local UI development before a backend exists).
#
# Expected endpoints when this is set:
#   GET {VITE_API_BASE_URL}/members
#   GET {VITE_API_BASE_URL}/members/:id
#   GET {VITE_API_BASE_URL}/volunteers
#   GET {VITE_API_BASE_URL}/volunteers/:id
#   GET {VITE_API_BASE_URL}/donations
#
# Each record is expected to roughly match the shape produced by
# src/data/mockData.js (id, name, email, phone, donations, status, gender, ...).
VITE_API_BASE_URL=
